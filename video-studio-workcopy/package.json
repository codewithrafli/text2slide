  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.1",
    "lucide-vue-next": "^0.468.0",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
