{
  "name": "ai-video-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.18",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "bun run server/index.ts",
